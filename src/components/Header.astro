---
import { Image } from 'astro:assets';
import { PROPERTIES, type PropertySlug } from '../consts';
import HeaderLink from './HeaderLink.astro';

import shedFlipsLogo from '../assets/brand/shed-flips-logo.jpg';
import packItLogo from '../assets/brand/imgonnapackit-logo.jpg';
import garageFlipsLogo from '../assets/brand/garage-flips-logo.jpg';
import podcastLogo from '../assets/brand/lonnie-and-ryan-logo.jpg';
import shopIcon from '../assets/brand/shop-icon.png';
import shopBanner from '../assets/brand/shop-banner.png';

interface Props {
	currentProperty?: PropertySlug;
}
const { currentProperty } = Astro.props;

const LOGOS: Record<PropertySlug, ImageMetadata> = {
	'shed-flips': shedFlipsLogo,
	'im-gonna-pack-it': packItLogo,
	'garage-flips': garageFlipsLogo,
	podcast: podcastLogo,
};

const NAV_PROPS: PropertySlug[] = ['shed-flips', 'im-gonna-pack-it', 'garage-flips', 'podcast'];

const pathname = Astro.url.pathname;
function isPropActive(slug: PropertySlug): boolean {
	if (pathname === `/${slug}` || pathname === `/${slug}/`) return true;
	if (pathname.startsWith(`/${slug}/`)) return true;
	return currentProperty === slug;
}
---

<header>
	<div class="header-inner">
		<nav class="nav-primary" aria-label="Channels">
			<div class="property-bar">
				{NAV_PROPS.map((slug) => {
					const p = PROPERTIES[slug];
					const active = isPropActive(slug);
					return (
						<a
							href={`/${slug}/`}
							class:list={['property-button', { 'is-active': active }]}
							style={`--prop-accent: ${p.accent}; --prop-chip-text: ${p.chipText};`}
							aria-current={active ? 'page' : undefined}
							aria-label={p.name}
						>
							<Image
								src={LOGOS[slug]}
								alt=""
								width={36}
								height={36}
								class="property-mark"
							/>
							<span class="property-name">{p.navLabel}</span>
						</a>
					);
				})}
				<a
					href="https://shop.shedflips.com"
					class="property-button"
					style="--prop-accent: #1B8038; --prop-chip-text: #FFFFFF;"
					target="_blank"
					rel="noopener"
					aria-label="Shop — opens in a new tab"
				>
					<Image
						src={shopIcon}
						alt=""
						width={36}
						height={36}
						class="property-mark"
					/>
					<span class="property-name">Shop</span>
				</a>
			</div>
		</nav>
		<nav class="nav-secondary" aria-label="Pages">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/faq">FAQ</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<button id="search-trigger" class="search-btn" aria-label="Search posts">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/>
					<line x1="21" y1="21" x2="16.65" y2="16.65"/>
				</svg>
				<span class="search-label">Search</span>
			</button>
		</nav>
	</div>
	<div class="accent-stripe" aria-hidden="true"></div>
</header>

<a
	href="https://shop.shedflips.com"
	class="shop-banner-link"
	target="_blank"
	rel="noopener"
	aria-label="Shop at Shed Flips — opens in a new tab"
>
	<Image
		src={shopBanner}
		alt="Shop at Shed Flips"
		widths={[480, 720, 960, 1200]}
		sizes="(max-width: 720px) 92vw, 800px"
		class="shop-banner-img"
	/>
</a>

<!-- Search overlay — lives outside <header> so it can cover the full viewport -->
<div id="search-overlay" class="search-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search">
	<div class="search-backdrop"></div>
	<div class="search-panel">
		<button id="search-close" class="search-close" aria-label="Close search">
			<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
				<line x1="18" y1="6" x2="6" y2="18"/>
				<line x1="6" y1="6" x2="18" y2="18"/>
			</svg>
		</button>
		<div id="search"></div>
	</div>
</div>

<style>
	header {
		margin: 0;
		background: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(8px);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.25em;
	}

	/* Primary row — channel buttons centered */
	.nav-primary {
		display: flex;
		justify-content: center;
		padding: 0.6em 0 0.55em 0;
	}
	.property-bar {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
		justify-content: center;
	}
	.property-button {
		display: inline-flex;
		align-items: center;
		gap: 0.55em;
		padding: 0.35em 0.85em 0.35em 0.45em;
		border-radius: 999px;
		border: 1px solid transparent;
		background: transparent;
		color: var(--text);
		font-weight: 600;
		font-size: 0.95em;
		text-decoration: none;
		line-height: 1.2;
		white-space: nowrap;
		transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
	}
	.property-button:hover {
		background: color-mix(in srgb, var(--prop-accent) 10%, transparent);
		border-color: color-mix(in srgb, var(--prop-accent) 40%, transparent);
		color: var(--prop-accent);
		border-bottom-color: color-mix(in srgb, var(--prop-accent) 40%, transparent);
	}
	.property-button.is-active {
		background: var(--prop-accent);
		border-color: var(--prop-accent);
		color: var(--prop-chip-text);
	}
	.property-mark {
		display: block;
		width: 1.85em;
		height: 1.85em;
		border-radius: 6px;
		object-fit: cover;
		flex-shrink: 0;
	}

	/* Secondary row — Home/FAQ/About + Search button on the right */
	.nav-secondary {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.6em;
		padding: 0.3em 0 0.4em 0;
		border-top: 1px solid var(--border);
	}
	.nav-secondary :global(a) {
		display: inline-block;
		padding: 0.35em 0.55em;
		color: var(--text-faint);
		font-size: 0.85em;
		font-weight: 500;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: color 0.15s ease;
	}
	.nav-secondary :global(a:hover) {
		color: var(--text-muted);
		border-bottom-color: transparent;
	}
	.nav-secondary :global(a.active) {
		color: var(--text);
		text-decoration: none;
		border-bottom-color: var(--accent);
		font-weight: 700;
	}
	.search-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		margin-left: 0.4em;
		padding: 0.3em 0.7em;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--text-muted);
		font-size: 0.8em;
		font-weight: 600;
		cursor: pointer;
		font-family: inherit;
		transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
	}
	.search-btn:hover {
		color: var(--text);
		border-color: var(--text-muted);
	}

	/* 4-color accent stripe across the bottom of the header — ties the
	   four properties together and replaces the plain 1px header border */
	.accent-stripe {
		height: 3px;
		background: linear-gradient(
			to right,
			#1B8038 0%, #1B8038 25%,
			#3D55B0 25%, #3D55B0 50%,
			#E59A0A 50%, #E59A0A 75%,
			#9C2C32 75%, #9C2C32 100%
		);
	}

	/* Search overlay */
	.search-overlay {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 10vh;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.15s ease;
	}
	.search-overlay.is-open {
		opacity: 1;
		pointer-events: all;
	}
	.search-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(20, 30, 22, 0.45);
		backdrop-filter: blur(4px);
	}
	.search-panel {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 640px;
		margin: 0 1em;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.25em;
		box-shadow: 0 24px 64px rgba(0, 0, 0, 0.18);
	}
	.search-close {
		position: absolute;
		top: 0.9em;
		right: 0.9em;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2em;
		height: 2em;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text-muted);
		cursor: pointer;
		transition: color 0.15s ease, border-color 0.15s ease;
		font-family: inherit;
	}
	.search-close:hover {
		color: var(--text);
		border-color: var(--text-muted);
	}
	#search {
		--pagefind-ui-scale: 0.9;
		--pagefind-ui-primary: var(--accent);
		--pagefind-ui-text: var(--text);
		--pagefind-ui-background: var(--surface);
		--pagefind-ui-border: var(--border);
		--pagefind-ui-border-radius: 8px;
		--pagefind-ui-font: inherit;
		--pagefind-ui-tag: var(--surface-2);
	}
	#search :global(.pagefind-ui__result-link) {
		color: var(--accent) !important;
	}

	/* Mobile: collapse property labels, keep avatars */
	@media (max-width: 720px) {
		.property-name {
			display: none;
		}
		.property-button {
			padding: 0.3em;
		}
		.search-label {
			display: none;
		}
		.search-btn {
			padding: 0.3em;
		}
		.nav-secondary {
			gap: 0.4em;
		}
	}
	@media (max-width: 480px) {
		.header-inner {
			padding: 0 0.75em;
		}
		.property-bar {
			gap: 0.25em;
		}
	}

	/* Shop banner — sits on every page just below the sticky header,
	   clickable link to the Shopify store. */
	.shop-banner-link {
		display: block;
		max-width: 800px;
		margin: 1.25em auto 0.5em auto;
		padding: 0 1.25em;
		transition: transform 0.15s ease, opacity 0.15s ease;
	}
	.shop-banner-link:hover {
		transform: translateY(-1px);
		opacity: 0.92;
	}
	.shop-banner-link:focus-visible {
		outline: 3px solid var(--accent, #1B8038);
		outline-offset: 4px;
		border-radius: 8px;
	}
	.shop-banner-img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 8px;
	}
	@media (max-width: 480px) {
		.shop-banner-link {
			margin: 0.9em auto 0.4em auto;
			padding: 0 0.75em;
		}
	}
</style>

<script is:inline>
	(function () {
		const trigger = document.getElementById('search-trigger');
		const overlay = document.getElementById('search-overlay');
		const backdrop = overlay.querySelector('.search-backdrop');
		const closeBtn = document.getElementById('search-close');
		let initialized = false;

		function openSearch() {
			overlay.classList.add('is-open');
			overlay.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';

			if (!initialized) {
				initialized = true;
				const link = document.createElement('link');
				link.rel = 'stylesheet';
				link.href = '/pagefind/pagefind-ui.css';
				document.head.appendChild(link);

				const showFallback = function () {
					document.getElementById('search').innerHTML =
						'<p style="color:var(--text-muted);padding:1em 0;font-size:0.9em">Search index not available — run <code>npm run build</code> to generate it.</p>';
				};
				const script = document.createElement('script');
				script.src = '/pagefind/pagefind-ui.js';
				script.async = true;
				script.onload = function () {
					if (typeof window.PagefindUI !== 'function') {
						showFallback();
						return;
					}
					new window.PagefindUI({
						element: '#search',
						showSubResults: false,
						resetStyles: false,
					});
					setTimeout(function () {
						const input = document.querySelector('#search input[type=text]');
						if (input) input.focus();
					}, 80);
				};
				script.onerror = showFallback;
				document.head.appendChild(script);
			} else {
				setTimeout(function () {
					const input = document.querySelector('#search input[type=text]');
					if (input) input.focus();
				}, 80);
			}
		}

		function closeSearch() {
			overlay.classList.remove('is-open');
			overlay.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			trigger.focus();
		}

		trigger.addEventListener('click', openSearch);
		closeBtn.addEventListener('click', closeSearch);
		backdrop.addEventListener('click', closeSearch);

		document.addEventListener('keydown', function (e) {
			if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
				closeSearch();
			}
			if (e.key === '/' && !overlay.classList.contains('is-open')) {
				const tag = document.activeElement && document.activeElement.tagName.toLowerCase();
				if (tag !== 'input' && tag !== 'textarea' && tag !== 'select') {
					e.preventDefault();
					openSearch();
				}
			}
		});
	})();
</script>
