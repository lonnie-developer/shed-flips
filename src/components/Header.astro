---
import { SITE_TITLE, CHANNEL_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">
			<span class="brand-mark" aria-hidden="true">SF</span>
			<span class="brand-name">{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="right-cluster">
			<button id="search-trigger" class="search-btn" aria-label="Search posts">
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/>
					<line x1="21" y1="21" x2="16.65" y2="16.65"/>
				</svg>
				<span class="search-label">Search</span>
			</button>
			<div class="social-links">
				<a href={CHANNEL_URL} target="_blank" rel="noopener" class="yt-link" aria-label="Shed Flips on YouTube">
					<svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28">
						<path
							fill="currentColor"
							d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
						/>
					</svg>
					<span>YouTube</span>
				</a>
			</div>
		</div>
	</nav>
</header>

<!-- Search overlay — lives outside <header> so it can cover the full viewport -->
<div id="search-overlay" class="search-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search">
	<div class="search-backdrop"></div>
	<div class="search-panel">
		<button id="search-close" class="search-close" aria-label="Close search">
			<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
				<line x1="18" y1="6" x2="6" y2="18"/>
				<line x1="6" y1="6" x2="18" y2="18"/>
			</svg>
		</button>
		<div id="search"></div>
	</div>
</div>

<style>
	header {
		margin: 0;
		padding: 0 1.25em;
		background: rgba(15, 15, 16, 0.85);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		max-width: 1100px;
		margin: 0 auto;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.6em;
		padding: 0.85em 0;
		font-weight: 700;
		color: var(--text);
		border-bottom: none;
	}
	.brand:hover {
		color: var(--accent);
		border-bottom-color: transparent;
	}
	.brand-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2em;
		height: 2em;
		background: var(--accent);
		color: #000;
		border-radius: 6px;
		font-weight: 800;
		font-size: 0.85em;
		letter-spacing: 0.05em;
	}
	.brand-name {
		font-size: 1.05em;
		letter-spacing: 0.01em;
	}
	.internal-links {
		display: flex;
		gap: 0.25em;
	}
	nav a {
		padding: 1em 0.75em;
		color: var(--text-muted);
		border-bottom: 2px solid transparent;
		text-decoration: none;
	}
	nav a:hover {
		color: var(--accent);
		border-bottom-color: transparent;
	}
	nav a.active {
		color: var(--text);
		border-bottom-color: var(--accent);
	}
	/* Right cluster: search button + YouTube link */
	.right-cluster {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.social-links {
		display: flex;
	}
	.yt-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.4em 0.85em !important;
		background: transparent;
		border: 1px solid var(--border) !important;
		border-radius: 6px;
		color: var(--text-muted);
		font-size: 0.9em;
		font-weight: 600;
	}
	.yt-link:hover {
		color: #000 !important;
		background: var(--accent);
		border-color: var(--accent) !important;
	}
	.yt-link svg {
		flex-shrink: 0;
	}
	/* Search trigger button */
	.search-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.4em 0.85em;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text-muted);
		font-size: 0.9em;
		font-weight: 600;
		cursor: pointer;
		font-family: inherit;
		transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
	}
	.search-btn:hover {
		color: var(--text);
		border-color: var(--text-muted);
	}
	/* Search overlay */
	.search-overlay {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding-top: 10vh;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.15s ease;
	}
	.search-overlay.is-open {
		opacity: 1;
		pointer-events: all;
	}
	.search-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(4px);
	}
	.search-panel {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 640px;
		margin: 0 1em;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.25em;
		box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
	}
	.search-close {
		position: absolute;
		top: 0.9em;
		right: 0.9em;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2em;
		height: 2em;
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text-muted);
		cursor: pointer;
		transition: color 0.15s ease, border-color 0.15s ease;
		font-family: inherit;
	}
	.search-close:hover {
		color: var(--text);
		border-color: var(--text-muted);
	}
	/* Pagefind UI theme overrides — maps Shed Flips dark palette onto Pagefind's CSS vars */
	#search {
		--pagefind-ui-scale: 0.9;
		--pagefind-ui-primary: var(--accent);
		--pagefind-ui-text: var(--text);
		--pagefind-ui-background: var(--surface);
		--pagefind-ui-border: var(--border);
		--pagefind-ui-border-radius: 8px;
		--pagefind-ui-font: inherit;
		--pagefind-ui-tag: var(--surface-2);
	}
	/* Ensure Pagefind result links use accent color */
	#search .pagefind-ui__result-link {
		color: var(--accent) !important;
	}
	@media (max-width: 720px) {
		.brand-name {
			display: none;
		}
		.yt-link span {
			display: none;
		}
		.yt-link {
			padding: 0.4em !important;
		}
		.search-label {
			display: none;
		}
		.search-btn {
			padding: 0.4em;
		}
	}
</style>

<script is:inline>
	(function () {
		const trigger = document.getElementById('search-trigger');
		const overlay = document.getElementById('search-overlay');
		const backdrop = overlay.querySelector('.search-backdrop');
		const closeBtn = document.getElementById('search-close');
		let initialized = false;

		function openSearch() {
			overlay.classList.add('is-open');
			overlay.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';

			if (!initialized) {
				initialized = true;
				// Load Pagefind CSS
				const link = document.createElement('link');
				link.rel = 'stylesheet';
				link.href = '/pagefind/pagefind-ui.css';
				document.head.appendChild(link);

				// Load Pagefind UI JS as a regular script — pagefind-ui.js is an
				// IIFE that attaches `window.PagefindUI`, not an ES module, so a
				// dynamic import() returns an empty namespace and fails to construct.
				const showFallback = function () {
					document.getElementById('search').innerHTML =
						'<p style="color:var(--text-muted);padding:1em 0;font-size:0.9em">Search index not available — run <code>npm run build</code> to generate it.</p>';
				};
				const script = document.createElement('script');
				script.src = '/pagefind/pagefind-ui.js';
				script.async = true;
				script.onload = function () {
					if (typeof window.PagefindUI !== 'function') {
						showFallback();
						return;
					}
					new window.PagefindUI({
						element: '#search',
						showSubResults: false,
						resetStyles: false,
					});
					// Focus the input once ready
					setTimeout(function () {
						const input = document.querySelector('#search input[type=text]');
						if (input) input.focus();
					}, 80);
				};
				script.onerror = showFallback;
				document.head.appendChild(script);
			} else {
				setTimeout(function () {
					const input = document.querySelector('#search input[type=text]');
					if (input) input.focus();
				}, 80);
			}
		}

		function closeSearch() {
			overlay.classList.remove('is-open');
			overlay.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			trigger.focus();
		}

		trigger.addEventListener('click', openSearch);
		closeBtn.addEventListener('click', closeSearch);
		backdrop.addEventListener('click', closeSearch);

		document.addEventListener('keydown', function (e) {
			if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
				closeSearch();
			}
			// '/' shortcut to open search (common convention, only when not typing)
			if (e.key === '/' && !overlay.classList.contains('is-open')) {
				const tag = document.activeElement && document.activeElement.tagName.toLowerCase();
				if (tag !== 'input' && tag !== 'textarea' && tag !== 'select') {
					e.preventDefault();
					openSearch();
				}
			}
		});
	})();
</script>
