---
interface Props {
	currentPage: number;
	lastPage: number;
	prevUrl: string | undefined;
	nextUrl: string | undefined;
	baseUrl?: string;
}

const { currentPage, lastPage, prevUrl, nextUrl, baseUrl = '/blog' } = Astro.props;

// Build the URL for a given page number
function pageUrl(n: number): string {
	return n === 1 ? `${baseUrl}/1` : `${baseUrl}/${n}`;
}

// Show at most 5 page buttons: always show first/last, and up to 3 around current
function buildPages(current: number, last: number): (number | '…')[] {
	if (last <= 7) return Array.from({ length: last }, (_, i) => i + 1);
	const pages: (number | '…')[] = [];
	const around = new Set([1, 2, current - 1, current, current + 1, last - 1, last].filter(n => n >= 1 && n <= last));
	let prev = 0;
	for (const n of [...around].sort((a, b) => a - b)) {
		if (n - prev > 1) pages.push('…');
		pages.push(n);
		prev = n;
	}
	return pages;
}

const pages = buildPages(currentPage, lastPage);
---

<nav class="pagination" aria-label="Blog pages">
	{prevUrl ? (
		<a href={prevUrl} class="pg-btn pg-arrow" aria-label="Previous page">
			← Prev
		</a>
	) : (
		<span class="pg-btn pg-arrow pg-disabled" aria-disabled="true">← Prev</span>
	)}

	<div class="pg-numbers">
		{pages.map((p) =>
			p === '…' ? (
				<span class="pg-ellipsis">…</span>
			) : p === currentPage ? (
				<span class="pg-btn pg-current" aria-current="page">{p}</span>
			) : (
				<a href={pageUrl(p)} class="pg-btn">{p}</a>
			)
		)}
	</div>

	{nextUrl ? (
		<a href={nextUrl} class="pg-btn pg-arrow" aria-label="Next page">
			Next →
		</a>
	) : (
		<span class="pg-btn pg-arrow pg-disabled" aria-disabled="true">Next →</span>
	)}
</nav>

<style>
	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5em;
		padding: 2em 0 1em 0;
		flex-wrap: wrap;
	}
	.pg-numbers {
		display: flex;
		align-items: center;
		gap: 0.35em;
	}
	.pg-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.2em;
		height: 2.2em;
		padding: 0 0.75em;
		border-radius: 6px;
		font-size: 0.9em;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid var(--border);
		background: var(--surface);
		color: var(--text);
		transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
		cursor: pointer;
	}
	a.pg-btn:hover {
		background: var(--surface-2);
		border-color: var(--accent);
		color: var(--accent);
	}
	.pg-current {
		background: var(--accent);
		border-color: var(--accent);
		color: #0f0f10;
		font-weight: 700;
		cursor: default;
	}
	.pg-disabled {
		opacity: 0.35;
		cursor: default;
	}
	.pg-arrow {
		padding: 0 1em;
	}
	.pg-ellipsis {
		color: var(--text-muted);
		padding: 0 0.25em;
		user-select: none;
	}
</style>
