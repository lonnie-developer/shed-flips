---
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import logo from '../assets/brand/shed-flips-logo.jpg';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<Image src={logo} alt="" width={48} height={48} class="brand-mark" />
			<div>
				<div class="brand-name">{SITE_TITLE}</div>
				<div class="brand-sub">Reselling stories across four YouTube channels</div>
			</div>
		</div>

		<div class="footer-links">
			<a href="/rss.xml" aria-label="RSS feed">RSS</a>
		</div>
	</div>

	<div class="affiliate-notice">
		As an Amazon Associate, {SITE_TITLE} earns from qualifying purchases.
	</div>

	<div class="copyright">
		&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
	</div>
</footer>
<style>
	footer {
		padding: 3em 1.25em 2em 1.25em;
		background: var(--surface);
		border-top: 1px solid var(--border);
		color: var(--text-muted);
	}
	.footer-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 2em;
		max-width: 1100px;
		margin: 0 auto 1.5em auto;
		flex-wrap: wrap;
	}
	.footer-brand {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.brand-mark {
		display: inline-block;
		width: 2.6em;
		height: 2.6em;
		border-radius: 8px;
		object-fit: contain;
	}
	.brand-name {
		font-weight: 700;
		color: var(--text);
		line-height: 1.1;
	}
	.brand-sub {
		font-size: 0.85em;
		color: var(--text-faint);
	}
	.footer-links {
		display: flex;
		gap: 1em;
		align-items: center;
	}
	.footer-links a {
		color: var(--text-muted);
		text-decoration: none;
		border-bottom: none;
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.yt-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
	}
	.affiliate-notice {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
		font-size: 0.8em;
		color: var(--text-faint);
		font-style: italic;
		padding-bottom: 0.75em;
	}
	.copyright {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
		font-size: 0.85em;
		color: var(--text-faint);
		padding-top: 1.5em;
		border-top: 1px solid var(--border);
	}
</style>
