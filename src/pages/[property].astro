---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { PROPERTIES, PROPERTY_SLUGS, type PropertySlug, SITE_TITLE } from '../consts';

import shedFlipsLogo from '../assets/brand/shed-flips-logo.jpg';
import packItLogo from '../assets/brand/imgonnapackit-logo.jpg';
import garageFlipsLogo from '../assets/brand/garage-flips-logo.jpg';
import podcastLogo from '../assets/brand/lonnie-and-ryan-logo.jpg';

const LOGOS: Record<PropertySlug, ImageMetadata> = {
	'shed-flips': shedFlipsLogo,
	'im-gonna-pack-it': packItLogo,
	'garage-flips': garageFlipsLogo,
	podcast: podcastLogo,
};

export async function getStaticPaths() {
	return PROPERTY_SLUGS.map((slug) => ({ params: { property: slug } }));
}

const { property: slug } = Astro.params as { property: PropertySlug };
const property = PROPERTIES[slug];
const logo = LOGOS[slug];

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((p) => (p.data.property ?? 'shed-flips') === slug)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Soft accent-tinted radial for the hero background.
const heroBg = `radial-gradient(ellipse at top, ${property.accent}1F, transparent 60%)`;
---

<!doctype html>
<html
	lang="en"
	style={`--accent: ${property.accent}; --accent-dark: ${property.accentDark};`}
>
	<head>
		<BaseHead
			title={`${property.name} — ${SITE_TITLE}`}
			description={property.description}
		/>
		<style>
			.hero {
				text-align: center;
				padding: 4em 1em 3em 1em;
				border-bottom: 1px solid var(--border);
			}
			.hero-mark {
				display: block;
				width: 7em;
				height: 7em;
				border-radius: 16px;
				margin: 0 auto 0.75em auto;
				object-fit: cover;
				box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
			}
			.hero h1 {
				font-size: 2.6em;
				margin: 0 0 0.25em 0;
			}
			.hero .tagline {
				color: var(--text-muted);
				font-size: 1.1em;
				font-style: italic;
				margin: 0 auto 1em auto;
			}
			.hero .description {
				color: var(--text);
				font-size: 1em;
				max-width: 38em;
				margin: 0 auto 1.75em auto;
				line-height: 1.6;
			}
			.hero-cta {
				display: inline-flex;
				gap: 0.75em;
				flex-wrap: wrap;
				justify-content: center;
			}
			.btn-secondary {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				background: transparent;
				color: var(--text);
				padding: 0.7em 1.2em;
				border-radius: 6px;
				font-weight: 600;
				border: 1px solid var(--border);
				text-decoration: none;
			}
			.btn-secondary:hover {
				color: var(--accent);
				border-color: var(--accent);
			}
			.posts {
				max-width: 1100px;
				margin: 0 auto;
				padding: 3em 1em;
			}
			.posts-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.5em;
				gap: 1em;
				flex-wrap: wrap;
			}
			.posts-header h2 {
				font-size: 1.6em;
				margin: 0;
			}
			.posts-header .count {
				color: var(--text-faint);
				font-size: 0.9em;
			}
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.25em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.empty-state {
				text-align: center;
				padding: 3em 1em;
				color: var(--text-muted);
				background: var(--surface);
				border: 1px dashed var(--border);
				border-radius: 10px;
			}
			.empty-state p {
				margin: 0 0 0.5em 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero" style={`background: ${heroBg};`}>
				<Image
					src={logo}
					alt={`${property.name} channel mark`}
					width={144}
					height={144}
					class="hero-mark"
				/>
				<h1>{property.name}</h1>
				<p class="tagline">{property.tagline}</p>
				<p class="description">{property.description}</p>
				<div class="hero-cta">
					<a class="btn-secondary" href="/">← All channels</a>
				</div>
			</section>

			<section class="posts">
				<div class="posts-header">
					<h2>Posts</h2>
					{posts.length > 0 && (
						<span class="count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
					)}
				</div>

				{posts.length === 0 ? (
					<div class="empty-state">
						<p>No posts yet for {property.name}.</p>
					</div>
				) : (
					<ul class="posts-grid">
						{posts.map((post) => (
							<PostCard post={post} />
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
